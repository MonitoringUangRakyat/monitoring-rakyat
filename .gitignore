# Local/editor noise
.DS_Store
Thumbs.db
*.log
*.tmp
*.bak

# Local runtime caches
node_modules/
__pycache__/
.pytest_cache/
.venv/
venv/

# Local-only exports and backups
*.sqlite-wal
*.sqlite-shm
*.db-wal
*.db-shm
monitoring-rakyat-data-*.json

# Large external source dumps stay local; import scripts turn them into small draft queues.
gudang-db/_intake/nemesis/*
!gudang-db/_intake/nemesis/.gitkeep

# Secrets/config that should not be committed
.env
.env.*
secrets/
